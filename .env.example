# =============================================================================
# MAIDAN Dojo Management System — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env to git.
# =============================================================================

# --- Django Core ---
DJANGO_SECRET_KEY=change-me-to-a-long-random-string-at-least-50-chars
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.development

# --- Database (PostgreSQL) ---
POSTGRES_DB=maidan
POSTGRES_USER=maidan_user
POSTGRES_PASSWORD=maidan_dev_password
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql://maidan_user:maidan_dev_password@db:5432/maidan

# --- Redis ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- Next.js / Auth.js ---
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-to-a-random-secret-for-nextauth
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- JWT Settings ---
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# --- S3 / Storage ---
USE_S3=False
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_STORAGE_BUCKET_NAME=maidan-media
AWS_S3_REGION_NAME=me-south-1
AWS_S3_ENDPOINT_URL=http://minio:9000
# Set to your CDN or S3 public URL in production
MEDIA_URL=http://localhost:8000/media/

# --- Email ---
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=your-sendgrid-api-key
DEFAULT_FROM_EMAIL=noreply@maidan.app

# --- Payment Providers ---
STRIPE_SECRET_KEY=sk_test_your_stripe_secret
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

PAYTABS_PROFILE_ID=your_paytabs_profile_id
PAYTABS_SERVER_KEY=your_paytabs_server_key
PAYTABS_REGION=SAU
PAYTABS_BASE_URL=https://secure.paytabs.sa

HYPERPAY_ACCESS_TOKEN=your_hyperpay_access_token
HYPERPAY_BASE_URL=https://eu-test.oppwa.com

# --- WhatsApp (360dialog) ---
WHATSAPP_PROVIDER=stub
WHATSAPP_API_KEY=your_360dialog_api_key
WHATSAPP_BASE_URL=https://waba.360dialog.io/v1

# --- Platform Settings ---
PLATFORM_NAME=MAIDAN
PLATFORM_DOMAIN=maidan.app
DEFAULT_CURRENCY=SAR
SUPPORTED_CURRENCIES=SAR,AED,USD,EUR
DEFAULT_LANGUAGE=ar

# --- Sentry / Monitoring (production) ---
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# --- MinIO (local S3 dev only) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
