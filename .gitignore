# MAIDAN — Root .gitignore

# Secrets
.env
.env.local
.env.*.local
*.pem

# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
*.egg
.eggs/
*.pot
*.pyc
.pytest_cache/
.mypy_cache/
htmlcov/
.coverage
.coverage.*

# Django
backend/staticfiles/
backend/media/
backend/locale/

# Node.js
node_modules/
frontend/.next/
frontend/out/
frontend/.env.local

# Docker
docker-compose.override.yml

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Backup files
backups/
*.sql.gz

# Certificates
nginx/ssl/*.pem
nginx/ssl/*.crt
nginx/ssl/*.key

# Logs
*.log
logs/
